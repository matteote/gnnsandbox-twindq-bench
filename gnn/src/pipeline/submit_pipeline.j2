"""Submit the GNN training pipeline to Vertex AI Pipelines.

Generated from gnn/pipeline/submit_pipeline.j2 by install.sh.

Usage:
    python submit_pipeline.py [options]

Options:
    --project       GCP project ID (default: from template)
    --region        GCP region (default: from template)
    --pipeline-root GCS pipeline root path
    --spanner-instance  Spanner instance name
    --spanner-database  Spanner database name
    --gcs-bucket    GCS bucket for model artefacts
    --sync          Wait for pipeline completion (default: False)
"""

import argparse
import sys
import os

# Defaults injected by Jinja at install time
DEFAULT_PROJECT = "{{ GOOGLE_PROJECT }}"
DEFAULT_REGION = "{{ GOOGLE_REGION }}"
DEFAULT_PIPELINE_ROOT = "{{ GOOGLE_PIPELINE_ROOT }}"
DEFAULT_GCS_BUCKET = "{{ GOOGLE_GNN_BUCKET }}"
DEFAULT_REPO = "{{ GOOGLE_REPO }}"

TRAIN_IMAGE = f"{DEFAULT_REGION}-docker.pkg.dev/{DEFAULT_PROJECT}/{DEFAULT_REPO}/traingnn-vertex:latest"
SERVE_IMAGE = f"{DEFAULT_REGION}-docker.pkg.dev/{DEFAULT_PROJECT}/{DEFAULT_REPO}/servegnn-vertex:latest"
SERVICE_ACCOUNT = f"networkagent@{DEFAULT_PROJECT}.iam.gserviceaccount.com"

# Inject the image URI so that @component(base_image=...) decorators in the
# pipeline components (e.g. ingest.py) pick up the correct image at compile
# time.  Must be set BEFORE the pipeline module is imported.
os.environ.setdefault("GNN_TRAIN_IMAGE_URI", TRAIN_IMAGE)


def compile_pipeline(output_path: str = "gnn_pipeline.yaml"):
    """Compile the KFP pipeline to a YAML spec file."""
    import sys
    # Ensure the pipeline directory is on the path
    pipeline_dir = os.path.dirname(os.path.abspath(__file__))
    if pipeline_dir not in sys.path:
        sys.path.insert(0, pipeline_dir)

    from kfp import compiler
    from pipeline import gnn_training_pipeline

    compiler.Compiler().compile(
        pipeline_func=gnn_training_pipeline,
        package_path=output_path,
    )
    print(f"Pipeline compiled to: {output_path}")
    return output_path


def submit_pipeline(
    project: str,
    region: str,
    pipeline_root: str,
    spanner_instance: str,
    spanner_database: str,
    gcs_bucket: str,
    train_image: str,
    serve_image: str,
    service_account: str,
    sync: bool = False,
    pipeline_yaml: str = "gnn_pipeline.yaml",
):
    """Compile and submit the pipeline to Vertex AI Pipelines."""
    from google.cloud import aiplatform

    aiplatform.init(project=project, location=region)

    compiled_path = compile_pipeline(pipeline_yaml)

    job = aiplatform.PipelineJob(
        display_name="gnn-training-pipeline",
        template_path=compiled_path,
        pipeline_root=pipeline_root,
        parameter_values={
            "project": project,
            "region": region,
            "train_image_uri": train_image,
            "serve_image_uri": serve_image,
            "spanner_instance": spanner_instance,
            "spanner_database": spanner_database,
            "gcs_bucket": gcs_bucket,
            "service_account": service_account,
        },
        enable_caching=False,
    )

    print(f"Submitting pipeline to Vertex AI Pipelines...")
    job.submit(service_account=service_account)

    print(f"Pipeline job submitted: {job.resource_name}")
    print(f"Monitor at: https://console.cloud.google.com/vertex-ai/pipelines?project={project}")

    if sync:
        print("Waiting for pipeline completion (--sync flag set)...")
        job.wait()
        print(f"Pipeline finished with state: {job.state}")
        if job.state.name != "PIPELINE_STATE_SUCCEEDED":
            sys.exit(1)

    return job.resource_name


def main():
    parser = argparse.ArgumentParser(description="Submit GNN training pipeline to Vertex AI")
    parser.add_argument("--project", default=DEFAULT_PROJECT)
    parser.add_argument("--region", default=DEFAULT_REGION)
    parser.add_argument("--pipeline-root", default=DEFAULT_PIPELINE_ROOT)
    parser.add_argument("--spanner-instance", default="networktopology-instance")
    parser.add_argument("--spanner-database", default="networktopology-db")
    parser.add_argument("--gcs-bucket", default=DEFAULT_GCS_BUCKET)
    parser.add_argument("--train-image", default=TRAIN_IMAGE)
    parser.add_argument("--serve-image", default=SERVE_IMAGE)
    parser.add_argument("--service-account", default=SERVICE_ACCOUNT)
    parser.add_argument("--sync", action="store_true", help="Wait for pipeline completion")
    parser.add_argument("--output-yaml", default="gnn_pipeline.yaml", help="Compiled pipeline YAML path")
    args = parser.parse_args()

    submit_pipeline(
        project=args.project,
        region=args.region,
        pipeline_root=args.pipeline_root,
        spanner_instance=args.spanner_instance,
        spanner_database=args.spanner_database,
        gcs_bucket=args.gcs_bucket,
        train_image=args.train_image,
        serve_image=args.serve_image,
        service_account=args.service_account,
        sync=args.sync,
        pipeline_yaml=args.output_yaml,
    )


if __name__ == "__main__":
    main()
