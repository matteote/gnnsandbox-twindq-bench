# Multi-stage build:
#   Stage 1 (builder) — compiles the Go binary with CGO disabled so it is
#                        fully static and runs on any Linux image.
#   Stage 2 (final)   — scratch image containing only the binary.
#                        This image is used as the "carrier" that the device
#                        Dockerfile COPYs the binary from.

# ── Stage 1: Build ────────────────────────────────────────────────────────────
FROM golang:1.22-alpine AS builder

WORKDIR /src

# Copy the module definition and download dependencies.
# go.sum is generated by `go mod tidy` if not yet committed.
COPY go.mod ./
RUN go mod download

# Copy full source and build.
COPY . .
RUN go mod tidy && CGO_ENABLED=0 GOOS=linux GOARCH=amd64 \
    go build -trimpath -ldflags="-s -w" \
    -o /traffic-agent ./cmd/agent

# ── Stage 2: Carrier image ────────────────────────────────────────────────────
# scratch has no shell, no libc, no nothing — just the binary.
# The device Dockerfile pulls from this image:
#   COPY --from=gcr.io/.../traffic-agent:latest /traffic-agent /usr/local/bin/
FROM scratch
COPY --from=builder /traffic-agent /traffic-agent
ENTRYPOINT ["/traffic-agent"]
